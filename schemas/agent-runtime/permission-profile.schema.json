{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fde.local/schemas/agent-runtime/permission-profile.schema.json",
  "title": "PermissionProfile",
  "type": "object",
  "required": ["name", "tools"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "enum": ["ci-readonly", "ci-yaml-edit", "diagnosis-readonly", "collaboration-notify"] },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "command_allowlist": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mcp_server_allowlist": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" }
    },
    "mcp_tool_allowlist": {
      "type": "array",
      "items": { "type": "string", "pattern": "^mcp__[A-Za-z0-9_-]+__[A-Za-z0-9_-]+$" }
    }
  }
}
