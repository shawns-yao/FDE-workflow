{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fde.local/schemas/agent-runtime/agent-task-result.schema.json",
  "title": "AgentTaskResult",
  "type": "object",
  "required": ["task_id", "status", "output", "artifact_refs", "token_usage", "permission_audit"],
  "additionalProperties": false,
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["succeeded", "failed", "blocked", "timed_out"] },
    "output": { "type": "string" },
    "structured_data": {},
    "artifact_refs": {
      "type": "array",
      "items": { "$ref": "../common/artifact.schema.json" }
    },
    "patch_ref": { "type": "string" },
    "tool_trace_ref": { "type": "string" },
    "token_usage": {
      "type": "object",
      "required": ["input_tokens", "output_tokens"],
      "additionalProperties": false,
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 }
      }
    },
    "permission_audit": {
      "type": "object",
      "required": ["profile", "blocked_tools"],
      "additionalProperties": false,
      "properties": {
        "profile": { "type": "string" },
        "blocked_tools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "error": { "$ref": "../common/error.schema.json" }
  }
}
