# FDE Workstation production env template
#
# Usage:
#   Linux: [ -f .env.production ] || cp .env.production.example .env.production
#   Edit .env.production, then run chmod 600 .env.production
#
# Notes:
# - Do not put real secrets in this template.
# - Do not overwrite an existing .env.production with this file.
# - docker-compose.prod.yml reads .env.production through env_file.
# - Production must use Redis as the event bus.

# -----------------------------------------------------------------------------
# Base service
# -----------------------------------------------------------------------------
FDE_ENVIRONMENT=prod
FDE_EVENT_BACKEND=redis
FDE_HTTP_HOST=0.0.0.0
FDE_HTTP_PORT=3412
FDE_HTTP_MAX_BODY_BYTES=1048576
FDE_HTTP_REQUEST_TIMEOUT_MS=5000
# Use the public service URL in production, for example https://fde.example.com.
FDE_PUBLIC_BASE_URL=https://fde.example.com

# -----------------------------------------------------------------------------
# Redis Streams event bus
# -----------------------------------------------------------------------------
# docker-compose.prod.yml uses the internal service name redis.
REDIS_URL=redis://redis:6379/0
REDIS_HOST=
REDIS_PORT=
REDIS_DB=
REDIS_PASSWORD=
REDIS_KEY_PREFIX=fde:
FDE_EVENT_STREAM=fde.events
FDE_EVENT_DLQ_STREAM=fde.events.dlq
FDE_REDIS_BLOCK_MS=5000
FDE_REDIS_BATCH_SIZE=10
FDE_REDIS_PENDING_IDLE_MS=30000

# -----------------------------------------------------------------------------
# Feishu connector
# -----------------------------------------------------------------------------
# openapi_bot is recommended for send, card update, mention, and callbacks.
FEISHU_MODE=openapi_bot
# websocket: official SDK long connection; only outbound 443 is required.
# http_callback: requires a public HTTPS callback URL and callback secrets.
# disabled: do not receive Feishu events; keep send-only capabilities.
FEISHU_EVENT_MODE=websocket
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TEST_CHAT_ID=
FEISHU_DEFAULT_CHAT_ID=
# webhook_bot compatibility fields; not recommended for production loop.
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# Feishu HTTP callback verification; only for FEISHU_EVENT_MODE=http_callback.
FEISHU_CALLBACK_VERIFICATION_TOKEN=
FEISHU_CALLBACK_SIGNING_SECRET=
# Optional encrypt key for encrypted Feishu callbacks.
FEISHU_CALLBACK_ENCRYPT_KEY=

# -----------------------------------------------------------------------------
# Feishu startup smoke message
# -----------------------------------------------------------------------------
# Deployment smoke only; display text comes from src/i18n/zh.json.
FDE_FEISHU_STARTUP_MESSAGE_ENABLED=false
FEISHU_STARTUP_MESSAGE_CHAT_ID=
FEISHU_STARTUP_MENTION_OPEN_IDS=
FEISHU_STARTUP_MENTION_FROM_CHAT_MEMBERS=false
FEISHU_STARTUP_MENTION_LIMIT=1
# open_url button; button text comes from src/i18n/zh.json.
FEISHU_STARTUP_ACTION_URL=
# acknowledge button requires openapi_bot and websocket or http_callback mode.
FEISHU_STARTUP_ENABLE_CALLBACK_ACTIONS=false

# -----------------------------------------------------------------------------
# Webhook ingress tokens
# -----------------------------------------------------------------------------
GITLAB_WEBHOOK_TOKEN=
TEKTON_REPORT_TOKEN=
ARGOCD_WEBHOOK_TOKEN=

# -----------------------------------------------------------------------------
# Compliance radar probes
# -----------------------------------------------------------------------------
GITLAB_BASE_URL=
GITLAB_TOKEN=
TEKTON_API_BASE_URL=
TEKTON_TOKEN=
ARGOCD_BASE_URL=
ARGOCD_TOKEN=
KUBERNETES_API_BASE_URL=
KUBERNETES_TOKEN=
# Legacy aliases; prefer KUBERNETES_*.
K8S_API_BASE_URL=
K8S_TOKEN=

# -----------------------------------------------------------------------------
# Pipeline Agent / GitOps
# -----------------------------------------------------------------------------
FDE_PIPELINE_GITOPS_REPO_URL=
FDE_PIPELINE_GITOPS_REPO_BRANCH=main
FDE_PIPELINE_GITOPS_REPO_TOKEN=
FDE_PIPELINE_IMAGE_FIELD_PATH=
FDE_PIPELINE_YAML_FILE_NAME=
FDE_PIPELINE_ARGOCD_API_URL=
FDE_PIPELINE_ARGOCD_TOKEN=
FDE_PIPELINE_WEBHOOK_TOKEN=
FDE_PIPELINE_GIT_USER_NAME=FDE Workstation
FDE_PIPELINE_GIT_USER_EMAIL=fde@example.com
FDE_PIPELINE_WORKING_DIRECTORY=.fde-workspace/pipeline
FDE_PIPELINE_MAX_RETRIES=3
FDE_PIPELINE_RETRY_DELAY_MS=3000
FDE_PIPELINE_ENABLE_COMPLIANCE_PREFLIGHT=false
FDE_PIPELINE_ENABLE_ARGOCD_SYNC=false
FDE_PIPELINE_ENABLE_YAML_GOVERNANCE=false
FDE_PIPELINE_ENABLE_BUILD_FIX=false
FDE_PIPELINE_RUNTIME_MODEL=claude-sonnet-4-20250514
FDE_PIPELINE_YAML_GOVERNANCE_PROMPT_REF=prompts/pipeline/yaml-governance.md
FDE_PIPELINE_YAML_GOVERNANCE_SCHEMA_REF=schemas/pipeline/yaml-governance-result.schema.json
FDE_PIPELINE_BUILD_FIX_PROMPT_REF=prompts/pipeline/build-fix.md
FDE_PIPELINE_BUILD_FIX_SCHEMA_REF=schemas/pipeline/build-fix-result.schema.json

# -----------------------------------------------------------------------------
# AI Runtime
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_VERSION=

# -----------------------------------------------------------------------------
# MCP tool integration
# -----------------------------------------------------------------------------
# JSON array string. Production should only configure trusted MCP servers.
FDE_RUNTIME_MCP_SERVERS=
